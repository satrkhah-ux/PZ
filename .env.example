# ── Supabase (new Pizzara Cloud project) ────────────────────────────────────
# Public values — safe in the browser (injected at runtime via window.__ENV__).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. BYPASSES row-level security. Never expose to the browser.
# The ONLY path that reads cost/profit and runs loyalty/summary rpc.
SUPABASE_SERVICE_ROLE_KEY=
# Direct Postgres connection string, used by `npm run db:apply` for migrations.
SUPABASE_DB_URL=

# ── Telegram stats bot (Phase 7) ────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
# Comma-separated chat IDs allowed to query the bot (the owner's).
TELEGRAM_OWNER_CHAT_IDS=

# ── Loyalty config (owner-tunable) ──────────────────────────────────────────
# 1 point per this many IQD spent.
POINTS_PER_IQD=250
# Points needed to redeem one reward.
POINTS_PER_REWARD=100
# IQD value granted when a reward is redeemed (applied as a discount).
REWARD_VALUE_IQD=3000
